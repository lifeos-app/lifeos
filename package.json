{
  "name": "lifeos-app",
  "private": true,
  "version": "1.19.23",
  "description": "LifeOS — Personal life operating system by Teddy's Cleaning Systems",
  "author": "Tewedros Gebrewubet <tewedros@teddyscleaning.com.au>",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "preview": "vite preview",
    "release": "bash scripts/release.sh",
    "build:desktop": "vite build --mode desktop",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:dev": "ELECTRON_ENV=1 vite build --mode desktop && electron .",
    "electron:build": "ELECTRON_ENV=1 vite build --mode desktop && electron-builder",
    "electron:build:linux": "ELECTRON_ENV=1 vite build --mode desktop && electron-builder --linux",
    "electron:build:win": "ELECTRON_ENV=1 vite build --mode desktop && electron-builder --win",
    "electron:build:mac": "ELECTRON_ENV=1 vite build --mode desktop && electron-builder --mac",
    "electron:build:arm64": "ELECTRON_ENV=1 vite build --mode desktop && electron-builder --linux --arm64",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@fontsource/orbitron": "^5.2.8",
    "@fontsource/poppins": "^5.2.7",
    "@supabase/supabase-js": "^2.95.3",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "better-sqlite3": "^12.8.0",
    "driver.js": "^1.4.0",
    "lucide-react": "^0.563.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0",
    "remark-gfm": "^4.0.1",
    "steamworks.js": "^0.4.0",
    "tone": "^15.1.22",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.11"
  },
  "build": {
    "appId": "app.lifeos.desktop",
    "productName": "LifeOS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!electron/schema.sql",
      "node_modules/better-sqlite3/**/*"
    ],
    "extraResources": [
      {
        "from": "electron/schema.sql",
        "to": "schema.sql"
      }
    ],
    "afterPack": "./electron/rebuild.js",
    "npmRebuild": true,
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "Office",
      "icon": "public/favicon.svg"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/favicon.svg"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "icon": "public/favicon.svg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.0",
    "@tauri-apps/cli": "^2.10.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "rollup-plugin-visualizer": "^7.0.0",
    "tailwindcss": "^4.2.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^3.1.1"
  }
}
